{
  "name": "brix-cms",
  "version": "2.0.1",
  "description": "Open-source self-hosted block-based CMS. Visual page builder, 38 blocks, drag-and-drop, headless REST API, Next.js 16, SQLite/PostgreSQL.",
  "private": false,
  "license": "MIT",
  "homepage": "https://github.com/king-lear/brix-cms#readme",
  "bugs": {
    "url": "https://github.com/king-lear/brix-cms/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/king-lear/brix-cms"
  },
  "files": [
    "src",
    "prisma/schema.prisma",
    "prisma/seed.ts",
    "public/robots.txt",
    "public/uploads/.gitkeep",
    "public/images/.gitkeep",
    ".env.example",
    "next.config.ts",
    "tailwind.config.js",
    "postcss.config.js",
    "tsconfig.json",
    "eslint.config.mjs",
    "README.md",
    "LICENSE",
    "BLOCKS-MANUAL.md",
    "docs-blocks.md"
  ],
  "keywords": [
    "cms",
    "headless-cms",
    "nextjs",
    "blocks",
    "open-source",
    "self-hosted",
    "page-builder",
    "prisma",
    "block-editor",
    "drag-and-drop",
    "typescript",
    "sqlite",
    "postgresql",
    "visual-editor",
    "content-management"
  ],
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "setup": "prisma db push && npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.1",
    "next": "16.1.1",
    "prisma": "^6.19.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5"
  }
}
