# ─────────────────────────────────────────────
# Brix CMS — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/brix"

# Security — generate with: openssl rand -hex 32
ENCRYPTION_KEY=""
NEXTAUTH_SECRET=""

# ── Stripe (optional) ──────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""

# Stripe Connect (optional — for multi-vendor/marketplace)
STRIPE_CLIENT_ID=""
PLATFORM_FEE_PERCENT="10"

# ── AI Providers (optional) ───────────────────
# Add API keys via the admin UI at /admin/ai-config
# Supported: Gemini, DeepSeek, Mistral, Ollama
# Keys are encrypted at rest (AES-256-GCM)

# ── Figma Integration (optional) ──────────────
FIGMA_ACCESS_TOKEN=""

# ── App URL ───────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
