generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Igual que Brix.Pro: Pages contienen Blocks directamente
model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?   // SEO meta description
  ogImage     String?   // SEO Open Graph image
  jsonData    String?   // Configuración de la página (color de fondo, etc.)
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  pageType    String    @default("standard")
  blocks      Block[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
}

// Bloque: unidad atómica de contenido. Igual que .NET Block
model Block {
  id        String   @id @default(cuid())
  type      String   // "HeroBlock", "TextBlock", etc.
  sortOrder Int      @default(0)
  jsonData  String?  // JSON con los datos del bloque: {"Title":{"Value":"..."},...}
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentId  String?  // Para bloques anidados (ColumnBlock contiene otros bloques)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([parentId])
}

// Configuración global del sitio (clave → valor)
model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON: site, stripe_setup, stripe_connect, etc.
}

// Librería de medios con soporte de carpetas (igual que .NET MediaController)
model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String   @unique
  folder    String   @default("")  // Subcarpeta relativa dentro de /uploads/
  type      String   // image, video, document
  size      Int
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// Categorías de producto
model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

// Productos para e-commerce (igual que .NET ProductEntity)
model Product {
  id             String    @id @default(cuid())
  name           String
  description    String?
  longDescription String?
  price          Float
  originalPrice  Float?
  currencySymbol String?
  stock          Int       @default(0)
  imageUrl       String?
  imagesJson     String?   // JSON array de URLs — hasta 6 imágenes
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  categoryName   String?   // Campo de categoría como string (igual que .NET)
  tags           String?
  sizes          String?   // Variantes separadas por coma
  colors         String?
  customOptions  String?
  badge          String?
  rating         Float?
  reviewCount    Int?
  sku            String?
  stripePriceId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  cartItems      CartItem[]
  orderItems     OrderItem[]
}

// Items del carrito (igual que .NET CartItem)
model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([productId])
}

// Órdenes (igual que .NET Order)
model Order {
  id              String      @id @default(cuid())
  sessionId       String
  stripeSessionId String?
  customerEmail   String?
  totalAmount     Float
  currency        String      @default("SEK")
  status          String      @default("pending")
  itemsJson       String?     // JSON con los items del pedido
  isRestaurant    Boolean     @default(false)
  restaurantName  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orderItems      OrderItem[]

  @@index([sessionId])
  @@index([createdAt])
}

// Items de orden (relación N:M entre Order y Product)
model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  price     Float
  quantity  Int
  createdAt DateTime @default(now())

  @@index([orderId])
}

// API Keys for external AI providers — stored AES-256-GCM encrypted
model ApiKey {
  id           String   @id @default(cuid())
  provider     String   @unique   // "gemini" | "deepseek" | "mistral"
  encryptedKey String              // hex-encoded ciphertext
  iv           String              // hex-encoded 16-byte IV
  authTag      String              // hex-encoded 16-byte GCM auth tag
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Users for authentication
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String
  name               String?
  role               String   @default("admin")
  twoFactorEnabled   Boolean  @default(false)
  twoFactorSecret    String?  // TOTP secret (base32)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// AI Usage Log - tracks token usage and cost per provider
model AiUsageLog {
  id            String   @id @default(cuid())
  provider      String   // "gemini", "deepseek", "mistral", "ollama"
  operation     String   // "Generate", "AskQuestions", "Chat"
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  cost          Float    @default(0)
  model         String?
  createdAt     DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
}

// AI Generation History - tracks AI-generated pages
model AiGenerationLog {
  id          String   @id @default(cuid())
  pageId      String?  // Page ID if created/updated
  pageTitle   String   // Page title at generation time
  prompt      String   // The prompt used
  provider    String   // Provider used
  mode        String   // "create" or "update"
  createdAt   DateTime @default(now())

  @@index([pageId])
  @@index([createdAt])
}
