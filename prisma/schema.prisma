generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  ogImage     String?
  jsonData    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  pageType    String    @default("standard")
  blocks      Block[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model Block {
  id        String   @id @default(cuid())
  type      String
  sortOrder Int      @default(0)
  jsonData  String?
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([parentId])
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String   @unique
  folder    String   @default("")
  type      String
  size      Int
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String?
  role             String   @default("admin")
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  price         Float
  originalPrice Float?
  stock         Int      @default(0)
  category      String?
  badge         String?
  imageUrl      String?
  slug          String   @unique
  isActive      Boolean  @default(true)
  isFeatured    Boolean  @default(false)
  sizes         String?
  colors        String?
  rating        Float?
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([category])
}

model Order {
  id          String   @id @default(cuid())
  status      String   @default("pending")
  total        Float
  customerEmail String?
  customerName String?
  shippingAddress String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  productName String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@index([orderId])
}
