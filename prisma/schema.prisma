generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String?
  ogImage     String?
  jsonData    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  pageType    String    @default("standard")
  blocks      Block[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
}

model Block {
  id        String   @id @default(cuid())
  type      String
  sortOrder Int      @default(0)
  jsonData  String?
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageId])
  @@index([parentId])
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Media {
  id        String   @id @default(cuid())
  filename  String
  path      String   @unique
  folder    String   @default("")
  type      String
  size      Int
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String?
  role             String   @default("admin")
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
